# Copy to .env and fill in values. Do not commit .env (see .gitignore).
# Config is loaded in nonprofit_platform.config.load_config() via python-dotenv.

# --- Postgres / Supabase (system of record) ---
DATABASE_DSN=postgresql://postgres:postgres@localhost:5432/postgres
DB_APPLICATION_NAME=nonprofit-platform

# --- Supabase Storage (raw XML artifacts) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=raw-filings
SUPABASE_STORAGE_PREFIX=irs-filings
ENABLE_STORAGE=true

# --- OpenAI (narrative enrichment only) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PROMPT_VERSION=v1
OPENAI_TIMEOUT_SECONDS=120
ENABLE_ENRICHMENT=false
ENABLE_INDEXING=false
DRY_RUN=false

# --- Worker / job queue tuning ---
REGISTRY_SAMPLE_LIMIT=250
FILING_SAMPLE_LIMIT=25
CLAIM_BATCH_SIZE=20
ENRICH_BATCH_SIZE=5
FETCH_CONCURRENCY=4
EXTRACT_CONCURRENCY=4
ENRICH_CONCURRENCY=2
INDEX_CONCURRENCY=4
JOB_MAX_ATTEMPTS=5
JOB_CLAIM_LEASE_SECONDS=600
JOB_HEARTBEAT_INTERVAL_SECONDS=30
ORCHESTRATOR_POLL_INTERVAL_SECONDS=5
REGISTRY_SYNC_INTERVAL_SECONDS=3600
FILING_DISCOVERY_INTERVAL_SECONDS=1800
STALE_CLAIM_RECOVERY_INTERVAL_SECONDS=60
OPENAI_REQUESTS_PER_MINUTE=60
FILING_YEARS_BACKFILL_START=2024

# --- IRS bulk source URLs (optional overrides) ---
IRS_EO_BMF_URL=https://www.irs.gov/pub/irs-soi/eo1.csv
IRS_PUBLICATION_78_URL=https://apps.irs.gov/pub/epostcard/data-download-pub78.zip
IRS_REVOCATION_URL=https://apps.irs.gov/pub/epostcard/data-download-revocation.zip
IRS_990_BASE_URL=https://apps.irs.gov/pub/epostcard/990/xml

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false
